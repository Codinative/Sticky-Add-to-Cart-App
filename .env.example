# ─── Sticky Add to Cart — environment template ───────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit the filled-in .env.
# See README.md → "Required environment" for the full description of each var.

# ── BigCommerce OAuth (from the BigCommerce developer portal app) ────────────
CLIENT_ID=your_bigcommerce_client_id
CLIENT_SECRET=your_bigcommerce_client_secret

# Public URL of THIS app's deployment (no trailing slash).
# Also used to build the storefront script src that BigCommerce injects.
BASE_URL=https://your-app-domain.com

# OAuth callback — must equal {BASE_URL}/api/auth and match the BC app's setting.
AUTH_CALLBACK=https://your-app-domain.com/api/auth

# ── Session signing ──────────────────────────────────────────────────────────
# Secret used to sign/verify the embedded-app `context` JWT. Use a long random
# string (e.g. `openssl rand -hex 32`). Keep it stable across deploys.
JWT_KEY=replace_with_a_long_random_secret

# ── Database ─────────────────────────────────────────────────────────────────
# Only "firebase" is implemented; this is also the default if unset.
DB_TYPE=firebase

# Firebase service-account credentials (Project settings → Service accounts).
FIRE_ADMIN_PROJECT_ID=your_firebase_project_id
FIRE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# Keep the literal \n escapes from the JSON key; they are unescaped at runtime.
FIRE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Optional: non-production BigCommerce environment ─────────────────────────
# Set BOTH together to point at a non-prod BigCommerce API/login host.
# Leave both unset for normal production use.
# API_URL=
# LOGIN_URL=
